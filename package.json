{
  "name": "@dawsson/airlock",
  "version": "0.4.0",
  "description": "Self-hosted Expo OTA update server — Hono library for Cloudflare Workers",
  "keywords": [
    "cloudflare-workers",
    "expo",
    "hono",
    "ota",
    "react-native",
    "updates"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dawsson/airlock.git"
  },
  "bin": {
    "airlock": "./src/cli.ts"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/memory": "./src/adapters/memory.ts",
    "./adapters/file": "./src/adapters/file.ts",
    "./adapters/cloudflare": "./src/adapters/cloudflare.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "e2e:server": "bun run src/e2e/local-server.ts",
    "e2e:ios-ota": "bun run src/e2e/ios-ota-loop.ts",
    "e2e:advanced": "bun run src/e2e/advanced-features.ts"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260218.0",
    "bun-types": "^1.3.9"
  }
}
